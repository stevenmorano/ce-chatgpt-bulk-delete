{
  "manifest_version": 3,
  "name": "Steve's Tools: ChatGPT Bulk Delete",
  "version": "1.0",
  "description": "A fast, local-first dashboard to search and bulk-delete your ChatGPT history.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "icons": {
    "16": "icon-128.png",
    "48": "icon-128.png",
    "128": "icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Open ChatGPT History Dashboard"
  }
}
